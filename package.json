{
  "name": "@tsparticles/cli-workspace",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm nx run-many -t build",
    "build:affected": "pnpm nx affected -t build",
    "build:ci": "pnpm nx run-many -t build:ci",
    "build:ci:affected": "pnpm nx affected -t build:ci",
    "lint": "pnpm nx run-many -t lint",
    "lint:ci": "pnpm nx run-many -t lint:ci",
    "show:projects": "pnpm nx show projects",
    "test": "pnpm nx run-many -t test",
    "test:ci": "pnpm nx run-many -t test:ci",
    "version:alpha": "pnpm nx release version prerelease --preid=alpha",
    "version:beta": "pnpm nx release version prerelease --preid=beta",
    "version:patch": "pnpm nx release version patch",
    "version:minor": "pnpm nx release version minor",
    "version:major": "pnpm nx release version major",
    "publish:alpha": "pnpm nx release publish --tag=alpha",
    "publish:beta": "pnpm nx release publish --tag=beta"
  },
  "devDependencies": {
    "@nx/js": "^22.7.1",
    "@nx/devkit": "^22.7.1",
    "nx": "^22.7.1",
    "nx-cloud": "^19.1.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.0.3"
}