{
  "name": "tsparticles-utils-root",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "build": "nx run-many -t build",
    "build:ci": "nx run-many -t build:ci",
    "build:affected": "nx affected -t build",
    "build:ci:affected": "nx affected -t build:ci",
    "version:alpha": "nx release version prerelease --preid=alpha",
    "version:beta": "nx release version prerelease --preid=beta",
    "version:patch": "nx release version patch",
    "version:minor": "nx release version minor",
    "version:major": "nx release version major",
    "publish:alpha": "nx release publish --tag=alpha",
    "publish:beta": "nx release publish --tag=beta"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@nx/js": "^22.7.1",
    "@nx/devkit": "^22.7.1",
    "nx": "^22.7.1",
    "nx-cloud": "^19.1.3",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.0.1"
}